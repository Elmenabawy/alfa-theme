{
  "$schema": "https://cdn.salla.network/schemas/twilight.json",
  "version": "1.0.0",
  "name": "Alfa",
  "author": {
    "name": "Alfa Theme",
    "email": "affiliateunion1@gmail.com"
  },
  "description": "Premium RTL-first Salla storefront theme — glassmorphism, CRO-baked, performance-budgeted.",
  "support": {
    "rtl": true,
    "ltr": true,
    "dark_mode": true
  },
  "fonts": [
    {
      "name": "Tajawal",
      "type": "google",
      "weights": [400, 500, 700, 800]
    },
    {
      "name": "IBM Plex Sans Arabic",
      "type": "google",
      "weights": [400, 500, 600, 700]
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": "الهوية البصرية | Brand & Colors",
      "fields": [
        {
          "id": "color_primary",
          "type": "color",
          "label": "اللون الأساسي | Primary",
          "format": "hex",
          "value": "#6d28d9"
        },
        {
          "id": "color_secondary",
          "type": "color",
          "label": "اللون الثانوي | Secondary",
          "format": "hex",
          "value": "#db2777"
        },
        {
          "id": "color_accent",
          "type": "color",
          "label": "لون التمييز | Accent",
          "format": "hex",
          "value": "#f59e0b"
        },
        {
          "id": "gradient_angle",
          "type": "number",
          "label": "زاوية التدرج | Gradient angle (deg)",
          "value": 135
        },
        {
          "id": "font_display",
          "type": "select",
          "label": "خط العناوين | Display font",
          "value": "Tajawal",
          "options": [
            { "label": "Tajawal", "value": "Tajawal" },
            { "label": "IBM Plex Sans Arabic", "value": "IBM Plex Sans Arabic" }
          ]
        },
        {
          "id": "enable_dark_mode_toggle",
          "type": "boolean",
          "label": "إظهار زر الوضع الليلي | Show dark-mode toggle",
          "value": true
        }
      ]
    },
    {
      "type": "group",
      "label": "شريط الإعلان | Announcement Bar",
      "fields": [
        {
          "id": "announcement_enabled",
          "type": "boolean",
          "label": "تفعيل | Enabled",
          "value": true
        },
        {
          "id": "announcement_text",
          "type": "string",
          "label": "النص | Text",
          "value": "شحن مجاني للطلبات فوق 200 ر.س 🚚"
        },
        {
          "id": "announcement_countdown_to",
          "type": "string",
          "label": "عدّاد تنازلي حتى (ISO date, اختياري) | Countdown to (ISO, optional)",
          "value": ""
        },
        {
          "id": "announcement_dismissable",
          "type": "boolean",
          "label": "قابل للإغلاق | Dismissable",
          "value": true
        }
      ]
    },
    {
      "type": "group",
      "label": "ميزات رفع التحويل | CRO Features",
      "fields": [
        {
          "id": "free_shipping_threshold",
          "type": "number",
          "label": "حد الشحن المجاني (ر.س) | Free-shipping threshold",
          "value": 200
        },
        {
          "id": "low_stock_threshold",
          "type": "number",
          "label": "حد تنبيه قرب النفاد | Low-stock badge under",
          "value": 5
        },
        {
          "id": "enable_social_proof",
          "type": "boolean",
          "label": "إظهار \"شاهده X شخص\" | Show viewers social proof",
          "value": true
        },
        {
          "id": "enable_exit_intent",
          "type": "boolean",
          "label": "تفعيل نافذة نية الخروج | Enable exit-intent modal",
          "value": true
        },
        {
          "id": "exit_intent_coupon",
          "type": "string",
          "label": "كود الخصم للخروج | Exit-intent coupon code",
          "value": "WELCOME10"
        },
        {
          "id": "enable_recently_viewed",
          "type": "boolean",
          "label": "إظهار شريط \"شاهدته مؤخراً\" | Show recently-viewed",
          "value": true
        },
        {
          "id": "gift_wrap_price",
          "type": "number",
          "label": "سعر تغليف الهدية (ر.س) | Gift-wrap price",
          "value": 15
        }
      ]
    }
  ],
  "components": {
    "home": {
      "sections": [
        { "key": "hero", "path": "partials.home.hero", "label": "الواجهة الرئيسية | Hero" },
        { "key": "featured", "path": "partials.home.featured-collections", "label": "المجموعات المميزة | Featured collections" },
        { "key": "you-may-like", "path": "partials.home.you-may-also-like", "label": "قد يعجبك أيضاً | You may also like" }
      ]
    }
  }
}
