{#
  header.twig — sticky glass header.
  - Adds .is-scrolled (app.js) to intensify glass + shadow past a scroll offset.
  - Expanding search with a glass autocomplete panel (results filled by Salla
    search via app.js; falls back to the native search page on submit).
  - Cart button opens the global cart drawer; count badge bounces on update.
  Icon-only buttons all carry aria-labels and ≥44px targets.
#}
<header class="site-header" data-header>
  <div class="container site-header__inner">

    <a href="{{ salla.url.get('/') }}" class="site-header__logo" aria-label="{{ salla.config.get('store.name') }} — الصفحة الرئيسية">
      {% if salla.config.get('store.logo') %}
        <img src="{{ salla.config.get('store.logo') }}" alt="{{ salla.config.get('store.name') }}" width="120" height="36" fetchpriority="high">
      {% else %}
        <span>{{ salla.config.get('store.name', 'Alfa') }}</span>
      {% endif %}
    </a>

    <nav class="site-nav" aria-label="التنقل الرئيسي">
      {% for item in salla.menus.get('header') %}
        <a href="{{ item.url }}">{{ item.title }}</a>
      {% endfor %}
    </nav>

    <div class="site-header__actions">
      {# ---- Search ---- #}
      <div class="search" data-search>
        <form class="search__field" role="search" action="{{ salla.url.get('search') }}" method="get">
          <input
            type="search"
            name="q"
            class="search__input"
            placeholder="ابحث عن منتج…"
            aria-label="بحث في المتجر"
            autocomplete="off"
            data-search-input
          >
        </form>
        <button type="button" class="btn-icon" data-search-toggle aria-label="فتح البحث" aria-expanded="false">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M20 20l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="search__results" data-search-results role="listbox" aria-label="نتائج البحث"></div>
      </div>

      {# ---- Theme toggle (optional) ---- #}
      {% if theme.settings.enable_dark_mode_toggle | default(true) %}
        <button type="button" class="btn-icon" data-theme-toggle aria-label="تبديل الوضع الليلي">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" data-icon-sun><circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="2"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
      {% endif %}

      {# ---- Wishlist ---- #}
      <a href="{{ salla.url.get('wishlist') }}" class="btn-icon" aria-label="المفضلة" data-wishlist-link style="position:relative">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20s-7-4.5-9.3-9C1 7.5 3 4.5 6.2 4.5c2 0 3.2 1.2 3.8 2.2.6-1 1.8-2.2 3.8-2.2 3.2 0 5.2 3 3.5 6.5C19 15.5 12 20 12 20z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        <span class="count-badge" data-wishlist-count hidden>0</span>
      </a>

      {# ---- Account ---- #}
      <a href="{{ salla.url.get('profile') }}" class="btn-icon" aria-label="حسابي">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>

      {# ---- Cart trigger (opens drawer) ---- #}
      <button type="button" class="btn-icon" data-cart-toggle aria-label="عربة التسوّق" style="position:relative">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 7h14l-1.2 11a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 7z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M9 7a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="2"/></svg>
        <span class="count-badge" data-cart-count hidden>0</span>
      </button>
    </div>
  </div>
</header>
