{#
  featured-collections.twig — bento grid of collections. Each tile: image
  (scales 1.05 on hover), persistent title, CTA that reveals on hover/focus.
  Pulls from section.settings.collections (merchant-picked) or falls back to
  salla.categories. Images carry width/height → no CLS.
#}
{% set s = section.settings | default({}) %}
{% set collections = s.collections | default(salla.categories.get({ limit: 5 })) %}
<section class="section container" aria-labelledby="featured-title" data-reveal>
  <div class="section__head">
    <h2 class="section__title" id="featured-title">{{ s.title | default('تسوّق حسب المجموعة') }}</h2>
    <a class="section__link" href="{{ salla.url.get('products') }}">عرض الكل ←</a>
  </div>

  <div class="bento">
    {% for c in collections %}
      <a class="bento__tile" href="{{ c.url }}" aria-label="{{ c.name }}">
        <img
          class="bento__img"
          src="{{ c.image | default('assets/images/placeholder-product.svg' | asset) }}"
          alt="{{ c.name }}"
          width="600" height="600"
          loading="lazy" decoding="async"
        >
        <div class="bento__overlay">
          <h3 class="bento__title">{{ c.name }}</h3>
          <span class="bento__cta btn btn--ghost" style="background:#fff;color:var(--color-text);border-color:transparent;padding-block:.55rem;padding-inline:1.1rem">
            تسوّق
          </span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>
