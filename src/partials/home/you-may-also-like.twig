{#
  you-may-also-like.twig — horizontal scroll-snap carousel, no JS library.
  Reuses product-card. Arrow buttons nudge scroll by one card (app.js wires
  them, and they're hidden from AT since the scroller itself is keyboard/
  swipe accessible). Works in RTL because scroll uses logical inline scrolling.
#}
{% set s = section.settings | default({}) %}
{% set products = s.products | default(salla.products.get({ limit: 10 })) %}
<section class="section container" aria-labelledby="ymal-title" data-reveal>
  <div class="section__head">
    <h2 class="section__title" id="ymal-title">{{ s.title | default('قد يعجبك أيضاً') }}</h2>
    <div class="carousel__nav" aria-hidden="true">
      <button type="button" class="btn-icon glass" data-carousel-prev aria-label="السابق">
        <svg viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button type="button" class="btn-icon glass" data-carousel-next aria-label="التالي">
        <svg viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <div class="carousel" data-carousel role="list">
    {% for product in products %}
      <div role="listitem">
        {% include 'partials.product-card' with { product: product } %}
      </div>
    {% endfor %}
  </div>
</section>
