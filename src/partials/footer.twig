{#
  footer.twig — mega footer: newsletter (inline email validation in app.js),
  link columns from Salla menus, payment icons, social, accessibility
  statement, store info. All links keyboard-reachable; icons carry labels.
#}
<footer class="site-footer">
  <div class="container site-footer__inner">

    {# ---- Newsletter ---- #}
    <section class="footer-newsletter has-grain" aria-labelledby="nl-title">
      <div>
        <h2 id="nl-title">انضمّ إلى نشرتنا البريدية</h2>
        <p style="margin:0;opacity:.9">أحدث المنتجات والعروض الحصرية في بريدك.</p>
      </div>
      <form class="newsletter-form" data-newsletter novalidate>
        <input
          type="email"
          name="email"
          class="newsletter-form__input"
          placeholder="بريدك الإلكتروني"
          aria-label="البريد الإلكتروني"
          autocomplete="email"
          required
        >
        <button type="submit" class="btn btn--ghost" style="background:#fff;color:var(--brand-primary);border-color:#fff">اشترك</button>
        <p class="newsletter-form__error" data-newsletter-error role="alert" aria-live="polite"></p>
      </form>
    </section>

    {# ---- Link columns ---- #}
    <nav class="footer-cols" aria-label="روابط التذييل">
      {% for col in salla.menus.get('footer') %}
        <div class="footer-col">
          <h3>{{ col.title }}</h3>
          {% for item in col.children %}
            <a href="{{ item.url }}">{{ item.title }}</a>
          {% endfor %}
        </div>
      {% else %}
        <div class="footer-col">
          <h3>المتجر</h3>
          <a href="{{ salla.url.get('/') }}">الرئيسية</a>
          <a href="{{ salla.url.get('products') }}">المنتجات</a>
          <a href="{{ salla.url.get('pages.about') }}">من نحن</a>
        </div>
        <div class="footer-col">
          <h3>المساعدة</h3>
          <a href="{{ salla.url.get('pages.shipping') }}">الشحن والتوصيل</a>
          <a href="{{ salla.url.get('pages.returns') }}">الاستبدال والاسترجاع</a>
          <a href="{{ salla.url.get('contact') }}">تواصل معنا</a>
        </div>
      {% endfor %}

      <div class="footer-col">
        <h3>تواصل اجتماعي</h3>
        <div class="social-links">
          <a class="btn-icon" href="{{ salla.config.get('store.social.instagram', '#') }}" aria-label="إنستغرام"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
          <a class="btn-icon" href="{{ salla.config.get('store.social.twitter', '#') }}" aria-label="إكس / تويتر"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17 3h3l-7 8 8 10h-6l-5-6-5 6H2l7.5-9L2 3h6l4.5 5.5L17 3z"/></svg></a>
          <a class="btn-icon" href="{{ salla.config.get('store.social.tiktok', '#') }}" aria-label="تيك توك"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15 3c.4 2.4 1.8 4 4 4.3V11c-1.6 0-3-.5-4-1.3V15a5.5 5.5 0 1 1-5.5-5.5c.3 0 .7 0 1 .1v3.2a2.4 2.4 0 1 0 1.5 2.2V3H15z"/></svg></a>
        </div>
      </div>
    </nav>

    {# ---- Accessibility statement ---- #}
    <p style="font-size:.82rem;color:var(--color-text-muted);max-width:60ch;margin:0">
      نلتزم بإتاحة متجرنا للجميع وفق معايير WCAG AA. لأي ملاحظة حول الوصول،
      <a href="{{ salla.url.get('contact') }}" style="color:var(--brand-primary);font-weight:600">تواصل معنا</a>.
    </p>

    {# ---- Bottom bar ---- #}
    <div class="footer-bottom">
      <span>© {{ "now" | date('Y') }} {{ salla.config.get('store.name', 'Alfa') }}. جميع الحقوق محفوظة.</span>
      <div class="payment-icons" aria-label="وسائل الدفع المتاحة">
        <img src="{{ 'assets/images/pay-mada.svg' | asset }}" alt="مدى" width="38" height="24" loading="lazy">
        <img src="{{ 'assets/images/pay-visa.svg' | asset }}" alt="Visa" width="38" height="24" loading="lazy">
        <img src="{{ 'assets/images/pay-mastercard.svg' | asset }}" alt="Mastercard" width="38" height="24" loading="lazy">
        <img src="{{ 'assets/images/pay-applepay.svg' | asset }}" alt="Apple Pay" width="38" height="24" loading="lazy">
      </div>
    </div>
  </div>
</footer>
