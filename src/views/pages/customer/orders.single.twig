{#
  customer/orders.single.twig — order success / order detail page.
  Celebratory hero (confetti via CSS, reduced-motion safe), order summary,
  and a track-order CTA. Used after checkout and from the orders list.
#}
{% extends 'layouts.master' %}

{% block content %}
<div class="container section">
  <div class="order-success has-grain glass" data-reveal>
    <div class="order-success__badge" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" width="40" height="40"><circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="2"/><path d="M7 12.5l3.2 3.2L17 9" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <h1 style="margin-block:.5rem">تمّ استلام طلبك! 🎉</h1>
    <p style="color:var(--color-text-muted);margin:0">
      شكراً لك. رقم طلبك <strong style="color:var(--color-text)">#{{ order.id | default('—') }}</strong> —
      أرسلنا تفاصيل التأكيد إلى بريدك.
    </p>

    {# Confetti dots — pure CSS, hidden under reduced motion #}
    <div class="confetti" aria-hidden="true">
      {% for i in 1..12 %}<span style="--c:{{ i }}"></span>{% endfor %}
    </div>
  </div>

  {# ---- Order summary ---- #}
  <div class="cart-page-grid" style="margin-block-start:2rem">
    <section class="glass" style="border-radius:var(--radius-lg);padding:1.25rem" aria-labelledby="os-items">
      <h2 id="os-items" style="font-size:1.1rem">ملخّص الطلب</h2>
      {% for item in order.items | default([]) %}
        <div class="cart-line">
          <img class="cart-line__img" src="{{ item.image }}" alt="" width="64" height="64" loading="lazy">
          <div>
            <div class="cart-line__name">{{ item.name }}</div>
            <small style="color:var(--color-text-muted)">الكمية: {{ item.quantity }}</small>
          </div>
          <div class="cart-line__price">{{ item.total }}</div>
        </div>
      {% endfor %}
      <div style="display:flex;justify-content:space-between;font-weight:800;padding-block-start:1rem">
        <span>الإجمالي</span><span>{{ order.total }}</span>
      </div>
    </section>

    <aside class="glass" style="border-radius:var(--radius-lg);padding:1.25rem;align-self:start">
      <h2 style="font-size:1.1rem">تتبّع الشحنة</h2>
      <p style="color:var(--color-text-muted);font-size:.9rem">سنخطرك فور شحن طلبك. يمكنك متابعة الحالة في أي وقت.</p>
      <a href="{{ order.tracking_url | default(link('profile')) }}" class="btn btn--primary btn--block">تتبّع طلبي</a>
      <a href="{{ link('products') }}" class="btn btn--ghost btn--block" style="margin-block-start:.5rem">متابعة التسوّق</a>
    </aside>
  </div>
</div>

<style>
  .order-success { text-align: center; padding: 2.5rem 1.5rem; border-radius: var(--radius-xl); position: relative; overflow: hidden; }
  .order-success__badge { display: inline-grid; place-items: center; width: 72px; height: 72px; border-radius: var(--radius-pill);
    color: var(--color-success); background: color-mix(in srgb, var(--color-success) 14%, transparent); margin-inline: auto; }
  .confetti { position: absolute; inset: 0; pointer-events: none; }
  .confetti span { position: absolute; inset-block-start: -10px; inset-inline-start: calc(var(--c) * 8%); width: 8px; height: 14px; border-radius: 2px;
    background: var(--gradient-accent); opacity: .8; animation: fall calc(2s + var(--c) * .12s) var(--ease-friendly) infinite; animation-delay: calc(var(--c) * .15s); }
  @keyframes fall { 0% { transform: translateY(-20px) rotate(0); opacity: 0; } 15% { opacity: .9; } 100% { transform: translateY(420px) rotate(320deg); opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .confetti { display: none; } }
  .cart-page-grid { display: grid; gap: 1.5rem; }
  @media (min-width: 1024px) { .cart-page-grid { grid-template-columns: 1fr 340px; } }
</style>
{% endblock %}
