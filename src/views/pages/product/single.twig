{#
  product/single.twig — Product Detail Page (PDP), real Salla conventions.
  Sticky gallery + thumbnail rail, in-place hover zoom, rich info column
  (brand, rating, savings, installments, highlights, delivery, share), variant
  chips (wrapping <salla-product-options>), accordion, reviews, mobile sticky
  add-to-cart, trust strip, related carousel. Cart/variants/reviews use Salla
  web components. First gallery image is the eager LCP; the rest lazy.
#}
{% extends 'layouts.master' %}

{% block content %}
<div class="container">
  <div class="pdp">

    {# ============================ GALLERY ============================ #}
    <div class="pdp__gallery" data-gallery>
      <div class="pdp__thumbs" role="tablist" aria-label="صور المنتج">
        {% for img in product.images %}
          <button type="button" class="pdp__thumb" role="tab" data-thumb="{{ loop.index0 }}" aria-current="{{ loop.first ? 'true' : 'false' }}" aria-label="{{ loop.index }}">
            <img src="{{ img.url | cdn(128) }}" alt="" width="64" height="64" loading="lazy" decoding="async">
          </button>
        {% endfor %}
      </div>

      <div class="pdp__stage" data-zoom>
        {% for img in product.images %}
          <img data-stage="{{ loop.index0 }}" src="{{ img.url }}" alt="{{ img.alt | default(product.name) }}"
               width="800" height="800" {% if loop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %} decoding="async" {% if not loop.first %}hidden{% endif %}>
        {% endfor %}
      </div>
    </div>

    {# ============================ INFO ============================ #}
    <div class="pdp__info">
      {% if product.brand %}<a class="pdp__brand" href="{{ product.brand.url }}">{{ product.brand.name }}</a>{% endif %}
      <h1 class="pdp__title">{{ product.name }}</h1>

      <div class="pdp__meta">
        {% if product.rating.average %}
          <span class="pdp__meta-rate">
            <span class="pdp__stars" aria-hidden="true" style="--rate: {{ (product.rating.average / 5 * 100) | round }}%">★★★★★</span>
            <a href="#reviews-title">{{ product.rating.average }} ({{ product.rating.count | default(0) }})</a>
          </span>
        {% endif %}
        {% if product.sku %}<span class="pdp__meta-dot">·</span><span class="pdp__sku">SKU: {{ product.sku }}</span>{% endif %}
      </div>

      <div class="pdp__price">
        <span class="pdp__price-now">{{ product.price }}</span>
        {% if product.is_on_sale %}
          <span class="pdp__price-was">{{ product.regular_price }}</span>
          <span class="pdp__save">تخفيض</span>
        {% endif %}
      </div>

      <div class="pdp__installments" aria-label="التقسيط">
        <salla-installment product-id="{{ product.id }}"></salla-installment>
        <p class="pdp__installments-fallback">قسّمها على 4 دفعات بدون فوائد — متاح عند الدفع.</p>
      </div>

      {% if theme.settings.get('enable_social_proof', true) %}
        <p class="pdp__social-proof" data-social-proof aria-live="polite">
          <svg viewBox="0 0 24 24" fill="none" width="16" height="16" aria-hidden="true"><circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="2"/><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z" stroke="currentColor" stroke-width="2"/></svg>
          <span data-social-proof-text></span>
        </p>
      {% endif %}

      {% set low = theme.settings.get('low_stock_threshold', 5) %}
      {% if product.quantity is not null and product.quantity > 0 and product.quantity <= low %}
        <p class="stock-badge" style="margin-block-end:1rem">بقي {{ product.quantity }}</p>
      {% endif %}

      {# Variant chips (Salla owns selection state) #}
      {% if product.options | length %}
        <div class="variants">
          <salla-product-options product-id="{{ product.id }}">
            {% for option in product.options %}
              <div class="variant" data-variant>
                <span class="variant__label">{{ option.name }}</span>
                <div class="chips" role="group" aria-label="{{ option.name }}">
                  {% for val in option.values %}
                    <button type="button" class="chip {{ option.type == 'color' ? 'chip--swatch' : '' }}" data-option-value="{{ val.id }}"
                            aria-pressed="{{ loop.first ? 'true' : 'false' }}" {% if val.is_available is defined and not val.is_available %}disabled{% endif %}
                            {% if option.type == 'color' %}style="background: {{ val.color | default('#ccc') }}"{% endif %} title="{{ val.name }}">{{ option.type == 'color' ? '' : val.name }}</button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </salla-product-options>
        </div>
      {% endif %}

      {% if product.highlights | default([]) | length %}
        <ul class="pdp__highlights">
          {% for h in product.highlights %}
            <li><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12.5l4 4 10-10" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg><span>{{ h }}</span></li>
          {% endfor %}
        </ul>
      {% endif %}

      <div class="pdp__delivery glass">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="7" cy="18" r="2" stroke="currentColor" stroke-width="2"/><circle cx="17" cy="18" r="2" stroke="currentColor" stroke-width="2"/></svg>
        <span>التوصيل المتوقّع: <strong>2 - 4 أيام</strong></span>
      </div>

      <div class="pdp-ship-bar" data-pdp-ship-bar hidden><span data-pdp-ship-text></span></div>

      {# Add to cart + wishlist #}
      <div style="display:flex; gap:.75rem; margin-block:1.25rem">
        <salla-add-product-button product-id="{{ product.id }}" class="btn btn--primary btn--lg btn--block" data-primary-add {% if not product.is_available %}disabled{% endif %}>
          {{ product.is_available ? 'أضف إلى السلة' : 'نفد المخزون' }}
        </salla-add-product-button>
        <button type="button" class="btn-icon glass" data-wishlist-toggle aria-pressed="false" aria-label="أضف للمفضلة"
                style="width:56px;height:56px;border-radius:var(--radius-lg)"
                data-product='{{ { id: product.id, name: product.name, price: product.price, image: product.image.url, url: product.url } | json_encode }}'>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" style="width:24px;height:24px"><path d="M12 20s-7-4.5-9.3-9C1 7.5 3 4.5 6.2 4.5c2 0 3.2 1.2 3.8 2.2.6-1 1.8-2.2 3.8-2.2 3.2 0 5.2 3 3.5 6.5C19 15.5 12 20 12 20z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        </button>
      </div>

      <salla-quick-buy product-id="{{ product.id }}"></salla-quick-buy>

      {# Share row #}
      <div class="pdp__share" data-share data-share-url="{{ product.url }}" data-share-title="{{ product.name }}">
        <span class="pdp__share-label">شارك:</span>
        <button type="button" class="btn-icon" data-share-native aria-label="مشاركة"><svg viewBox="0 0 24 24" fill="none"><circle cx="18" cy="5" r="3" stroke="currentColor" stroke-width="2"/><circle cx="6" cy="12" r="3" stroke="currentColor" stroke-width="2"/><circle cx="18" cy="19" r="3" stroke="currentColor" stroke-width="2"/><path d="M8.7 10.7l6.6-3.9M8.7 13.3l6.6 3.9" stroke="currentColor" stroke-width="2"/></svg></button>
        <a class="btn-icon" data-share-wa target="_blank" rel="noopener" aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.2L2 22l4.9-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.4-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.2 0-.3 0-.5s-.5-1.3-.7-1.7-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-.9 2.2c0 1.3.9 2.5 1 2.7s1.9 2.9 4.6 4c1.7.7 2.3.8 3.1.7.5-.1 1.4-.6 1.6-1.1s.2-1 .1-1.1-.2-.2-.4-.3z"/></svg></a>
        <button type="button" class="btn-icon" data-share-copy aria-label="نسخ الرابط"><svg viewBox="0 0 24 24" fill="none"><rect x="9" y="9" width="11" height="11" rx="2" stroke="currentColor" stroke-width="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10" stroke="currentColor" stroke-width="2"/></svg></button>
        <small data-share-copied aria-live="polite"></small>
      </div>

      {% include 'components.trust-strip' %}

      {# Accordion #}
      <div class="accordion" style="margin-block-start:1.5rem">
        {% set panels = [
          { t: 'الوصف', c: product.description },
          { t: 'الشحن والإرجاع', c: 'شحن خلال 2-4 أيام. إرجاع مجاني خلال 14 يوماً.' }
        ] %}
        {% for p in panels %}
          <div class="accordion__item">
            <button type="button" class="accordion__btn" aria-expanded="{{ loop.first ? 'true' : 'false' }}" data-accordion>
              {{ p.t }}
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="accordion__panel" {% if loop.first %}style="max-height:none"{% endif %}>
              <div class="accordion__panel-inner">{{ p.c | raw }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {# ============================ REVIEWS ============================ #}
  <section class="section" aria-labelledby="reviews-title" data-reveal>
    <h2 class="section__title" id="reviews-title">التقييمات</h2>
    <div class="reviews__summary">
      <div>
        <div class="reviews__score">{{ product.rating.average | default('0') }}</div>
        <div aria-hidden="true" style="color:var(--brand-accent)">★★★★★</div>
        <small style="color:var(--color-text-muted)">{{ product.rating.count | default(0) }} تقييم</small>
      </div>
      <div>
        {% for star in 5..1 %}
          {% set pct = product.rating.stars[star] | default((star == 5) ? 72 : (star == 4) ? 18 : 4) %}
          <div class="review-bar">
            <span>{{ star }} ★</span>
            <span class="review-bar__track"><span class="review-bar__fill" style="width: {{ pct }}%"></span></span>
            <span>{{ pct }}%</span>
          </div>
        {% endfor %}
      </div>
    </div>
    <salla-rating-modal product-id="{{ product.id }}"></salla-rating-modal>
  </section>

  {# ============================ RELATED ============================ #}
  {% if product.related | default([]) | length %}
    {% include 'components.home.you-may-also-like' with { products: product.related, title: 'منتجات مشابهة' } %}
  {% endif %}
</div>

{# Mobile sticky add-to-cart #}
<div class="sticky-cta glass-strong" data-sticky-cta>
  <div style="flex:1; min-width:0">
    <strong style="display:block; font-size:.85rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis">{{ product.name }}</strong>
    <span style="font-weight:800">{{ product.price }}</span>
  </div>
  <salla-add-product-button product-id="{{ product.id }}" class="btn btn--primary" {% if not product.is_available %}disabled{% endif %}>
    أضف للسلة
  </salla-add-product-button>
</div>
{% endblock %}

{% block scripts %}
<script type="application/json" id="pdp-product">
  {{ { id: product.id, name: product.name, price: product.price, image: product.image.url, url: product.url } | json_encode | raw }}
</script>
{% endblock %}
