{#
  footer.twig — mega footer. Our gradient newsletter + glass styling wrap
  Salla's framework components. Arabic text inline (Arabic-first store).
#}
<footer class="site-footer">
  <div class="container site-footer__inner">

    {# ---- Newsletter ---- #}
    <section class="footer-newsletter has-grain" aria-labelledby="nl-title">
      <div>
        <h2 id="nl-title">انضمّ إلى نشرتنا البريدية</h2>
        <p style="margin:0;opacity:.9">أحدث المنتجات والعروض الحصرية تصلك أولاً.</p>
      </div>
      <form class="newsletter-form" data-newsletter novalidate>
        <input type="email" name="email" class="newsletter-form__input" placeholder="بريدك الإلكتروني" aria-label="البريد الإلكتروني" autocomplete="email" required>
        <button type="submit" class="btn newsletter-form__btn">اشترك</button>
        <p class="newsletter-form__error" data-newsletter-error role="alert" aria-live="polite"></p>
      </form>
    </section>

    {# ---- Columns ---- #}
    <div class="footer-cols">
      <div class="footer-col footer-col--brand">
        <a href="{{ store.url }}" class="site-header__logo" style="font-size:1.25rem">
          {% if store.logo %}<img src="{{ store.logo | cdn(160) }}" alt="{{ store.name }}" width="120" height="36" loading="lazy">{% else %}<span>{{ store.name }}</span>{% endif %}
        </a>
        {% if store.description %}<p class="footer-col__about">{{ store.description | raw }}</p>{% endif %}
        <div class="footer-social"><salla-social></salla-social></div>
      </div>

      <div class="footer-col">
        <h3>روابط مهمة</h3>
        <salla-menu source="footer"></salla-menu>
      </div>

      <div class="footer-col">
        <h3>تواصل معنا</h3>
        <salla-contacts></salla-contacts>
      </div>

      <div class="footer-col">
        <h3>طرق الدفع</h3>
        <salla-payments class="footer-payments"></salla-payments>
        <div style="margin-block-start:.75rem"><salla-trust-badges></salla-trust-badges></div>
      </div>
    </div>

    {# ---- Bottom bar ---- #}
    <div class="footer-bottom">
      <span class="copyright-text">© {{ 'now' | date('Y') }} {{ store.name }} — جميع الحقوق محفوظة</span>
      <a href="{{ link('contacts') }}" class="footer-bottom__a11y">نلتزم بإتاحة المتجر للجميع وفق معايير WCAG AA</a>
    </div>
  </div>
</footer>
