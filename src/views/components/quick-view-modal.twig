{#
  quick-view-modal.twig — empty modal shell mounted once globally. quick-view.js
  fetches product data on demand (salla.product.getDetails) and fills the panel,
  showing skeletons while loading so there is no layout jump. Esc/overlay close
  + focus trap handled in JS.
#}
<div class="modal" data-quick-view-modal role="dialog" aria-modal="true" aria-labelledby="qv-title" data-open="false" hidden>
  <div class="modal__panel" data-qv-panel>
    <button type="button" class="btn-icon modal__close" data-qv-close aria-label="إغلاق العرض السريع">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>

    <div class="quick-view__grid" data-qv-content>
      {# Skeleton state (default before hydrate) #}
      <div class="quick-view__media skeleton"></div>
      <div>
        <div class="skeleton skeleton--title" style="margin-block-end:1rem"></div>
        <div class="skeleton skeleton--text" style="width:30%"></div>
        <div class="skeleton skeleton--text" style="width:90%;margin-block:1rem"></div>
        <div class="skeleton skeleton--pill"></div>
      </div>
    </div>
  </div>
</div>
