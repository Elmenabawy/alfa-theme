{#
  category-links.twig — circular category / custom-link strip (story-style nav).
  Source toggle:
    • mode = 'categories' → pulls salla.categories (uses category images)
    • mode = 'custom'     → uses a `links` collection (image + label + url)
  Horizontal scroll-snap on mobile, centered grid on desktop. Images are square
  with width/height set → zero CLS. Reveal stagger per item.
#}
{% set s = component | default(section.settings) | default({}) %}
{% set title = s.title | default('تسوّق حسب الفئة') %}
{% set mode  = s.mode | default('categories') %}
{% set shape = s.shape | default('circle') %}   {# circle | squircle #}

{% if mode == 'custom' and s.links is defined %}
  {% set items = s.links %}
{% else %}
  {% set items = [] %}
  {% for c in salla.categories.get({ limit: 10 }) %}
    {% set items = items | merge([{ label: c.name, url: c.url, image: c.image }]) %}
  {% endfor %}
{% endif %}

<section class="section container cat-links cat-links--{{ shape }}" aria-labelledby="cl-title" data-reveal>
  {% if title %}<div class="section__head"><h2 class="section__title" id="cl-title">{{ title }}</h2></div>{% endif %}

  <ul class="cat-links__track" role="list">
    {% for it in items %}
      <li class="cat-links__item" data-reveal style="--reveal-i: {{ loop.index0 }}">
        <a href="{{ it.url | default('#') }}" aria-label="{{ it.label }}">
          <span class="cat-links__media">
            <img
              src="{{ it.image | default('assets/images/placeholder-product.svg' | asset) }}"
              alt="{{ it.label }}"
              width="160" height="160"
              loading="lazy" decoding="async"
            >
          </span>
          <span class="cat-links__label">{{ it.label }}</span>
        </a>
      </li>
    {% endfor %}
  </ul>
</section>
