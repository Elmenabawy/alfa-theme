{#
  category-links.twig — circular/squircle category-or-links strip (home builder).
  show_cats=true → uses component.categories (Salla provides selected categories
  with name/url/image). Otherwise uses component.links (custom: icon/title/url).
  Mirrors Salla's main-links data model. Scroll-snap on mobile; reveal stagger.
#}
{% set title = component.title | default('تسوّق حسب الفئة') %}
{% set shape = component.shape | default('circle') %}

<section class="section container cat-links cat-links--{{ shape }}" aria-labelledby="cl-title" data-reveal>
  {% if title %}<div class="section__head"><h2 class="section__title" id="cl-title">{{ title }}</h2></div>{% endif %}

  <ul class="cat-links__track" role="list">
    {% if component.show_cats %}
      {% for cat in component.categories %}
        <li class="cat-links__item" data-reveal style="--reveal-i: {{ loop.index0 }}">
          <a href="{{ cat.url }}" aria-label="{{ cat.name }}">
            <span class="cat-links__media">
              <img src="{{ cat.image | default(theme.settings.get('placeholder') | asset) }}" alt="{{ cat.name }}" width="160" height="160" loading="lazy" decoding="async">
            </span>
            <span class="cat-links__label">{{ cat.name }}</span>
          </a>
        </li>
      {% endfor %}
    {% else %}
      {% for link in component.links %}
        {% if link.title %}
          <li class="cat-links__item" data-reveal style="--reveal-i: {{ loop.index0 }}">
            <a href="{{ link.url | default('#') }}" aria-label="{{ link.title }}">
              <span class="cat-links__media cat-links__media--icon"><i class="{{ link.icon | default('sicon-store2') }}" aria-hidden="true"></i></span>
              <span class="cat-links__label">{{ link.title }}</span>
            </a>
          </li>
        {% endif %}
      {% endfor %}
    {% endif %}
  </ul>
</section>
