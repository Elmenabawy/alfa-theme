{#
  hero.twig — full-bleed hero (home builder component, reads component.*).
  LCP image is eager + fetchpriority="high" with width/height (protects LCP/CLS).
  Headline words wrapped in <span class="word"> for the staggered reveal.
  Parallax is transform-only (app.js) and off under reduced motion.
#}
{% set s = component | default(section.settings) | default({}) %}
{% set headline = s.title | default('أناقة تُلهم يومك') %}
<section class="hero has-grain" data-parallax-scene>
  <div class="hero__media">
    <img class="hero__img"
         src="{{ s.image | default(theme.settings.get('placeholder') | asset) }}"
         alt="{{ s.image_alt | default(headline) }}"
         width="1600" height="900" fetchpriority="high" decoding="async" data-parallax>
  </div>
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="container hero__content">
    {% if s.eyebrow %}<span class="hero__eyebrow">{{ s.eyebrow }}</span>{% endif %}

    <h1 class="hero__title" data-word-reveal>
      {% for word in headline | split(' ') %}
        <span class="word" style="--i: {{ loop.index0 }}">{{ word }}</span>{{ ' ' }}
      {% endfor %}
    </h1>

    {% if s.subtitle %}<p class="hero__sub">{{ s.subtitle }}</p>{% endif %}

    <div class="hero__cta">
      {% if s.primary_label | default('تسوّق الآن') %}
        <a href="{{ s.primary_url | default(link('products')) }}" class="btn btn--primary btn--lg">{{ s.primary_label | default('تسوّق الآن') }}</a>
      {% endif %}
      {% if s.secondary_label %}
        <a href="{{ s.secondary_url | default('#') }}" class="btn btn--ghost btn--lg">{{ s.secondary_label }}</a>
      {% endif %}
    </div>
  </div>
</section>
